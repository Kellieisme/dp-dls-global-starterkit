# Environment variables for NPM authentication
# Copy this file to .env and fill in your actual tokens

# GitHub Personal Access Token for npm.pkg.github.com
# Generate at: https://github.com/settings/tokens
# Required scopes: read:packages
NPM_TOKEN=your_github_personal_access_token_here

# Setup Instructions:
# 1. Copy .npmrc.template to .npmrc
# 2. Replace YOUR_GITHUB_TOKEN_HERE with your actual GitHub token
# 3. The .npmrc file will be ignored by git for security
